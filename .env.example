# BoKe Environment Configuration
# Copy this file to .env and fill in the required values.

# --- Security (REQUIRED) ---
# JWT secret key — must be >= 32 characters
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# --- Database ---
DATABASE_URL=sqlite:///./data/app.db

# --- Storage ---
STORAGE_PATH=./storage
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,md,png,jpg,jpeg

# --- Profile Images ---
IMAGE_MAX_UPLOAD_SIZE_MB=2
IMAGE_ALLOWED_EXTENSIONS=png,jpg,jpeg,webp,gif

# --- CORS ---
CORS_ORIGINS=http://localhost:5173

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0

# --- Rate Limiting ---
RATE_LIMIT_LOGIN=5

# --- Chat / LLM ---
CHAT_MAX_TIMEOUT=120
CHAT_MAX_MESSAGE_LENGTH=8000
CHAT_RATE_LIMIT_PER_MINUTE=20

# --- Registration ---
REGISTRATION_ENABLED=false

# --- Logging ---
LOG_LEVEL=INFO
